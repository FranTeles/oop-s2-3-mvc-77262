@model VgcCollege.Web.Models.StudentProfile

@{
    ViewData["Title"] = "Delete Student";
}

<div class="page-header">
    <h2>Delete Student</h2>
</div>

<div class="details-card">
    <p class="text-danger fw-bold">Are you sure you want to delete this student?</p>

    <dl class="row">
        <dt class="col-sm-3">Full Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3">Phone</dt>
        <dd class="col-sm-9">@Model.Phone</dd>

        <dt class="col-sm-3">Address</dt>
        <dd class="col-sm-9">@Model.Address</dd>

        <dt class="col-sm-3">Student Number</dt>
        <dd class="col-sm-9">@Model.StudentNumber</dd>
    </dl>

    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger me-2">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>