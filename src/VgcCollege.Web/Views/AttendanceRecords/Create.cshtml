@model VgcCollege.Web.Models.AttendanceRecord

@{
    ViewData["Title"] = "Create";
}

<div class="page-header">
    <h1>Create Attendance</h1>
</div>

<div class="form-card">
    <div class="row">
        <div class="col-lg-8">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="mb-3">
                    <label asp-for="CourseEnrolmentId" class="form-label"></label>
                <select asp-for="CourseEnrolmentId" class ="form-control" asp-items="ViewBag.CourseEnrolmentId"></select>
            </div>
                <div class="mb-3">
                    <label asp-for="WeekNumber" class="form-label"></label>
                <input asp-for="WeekNumber" class="form-control" />
                <span asp-validation-for="WeekNumber" class="text-danger"></span>
            </div>
            <div class="form-group">
                    <label asp-for="Date" class="form-label"></label>
                <input asp-for="Date" class="form-control" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Present" /> @Html.DisplayNameFor(model => model.Present)
                </label>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
