@model IEnumerable<VgcCollege.Web.Models.AttendanceRecord>

@{
    ViewData["Title"] = "Attendance";
}

<div class="page-header">
    <h2>Attendance Records</h2>

    @if (User.IsInRole("Admin") || User.IsInRole("Faculty"))
    {
        <a asp-action="Create" class="btn btn-primary">Add Attendance</a>
    }
</div>

<div class="table-card">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>Student</th>
                <th>Course</th>
                <th>Week</th>
                <th>Date</th>
                <th>Status</th>
                <th style="width: 260px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CourseEnrolment?.StudentProfile?.Name</td>
                    <td>@item.CourseEnrolment?.Course?.Name</td>
                    <td>@item.WeekNumber</td>
                    <td>@item.Date.ToShortDateString()</td>
                    <td>
                        @if (item.Present)
                        {
                            <span class="badge bg-success">Present</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Absent</span>
                        }
                    </td>
                    <td class="table-actions">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-details">Details</a>

                        @if (User.IsInRole("Admin") || User.IsInRole("Faculty"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-edit">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action btn-delete">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>