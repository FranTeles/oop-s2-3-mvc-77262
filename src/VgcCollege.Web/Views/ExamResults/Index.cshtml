@model IEnumerable<VgcCollege.Web.Models.ExamResult>

@{
    ViewData["Title"] = "Index";
}

<div class="page-header">
    <h2>Exam Result</h2>
    <a asp-action="Create" class="btn btn-primary">Create Exam Result</a>
</div>

<div class="table-card">
    <table class="table table-hover align-middle mb-0">
        <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Exam)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StudentProfile)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Score)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Grade)
            </th>
                <th style="width: 240px;">Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Exam.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StudentProfile.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Score)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Grade)
            </td>
                    <td class="table-actions">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-edit">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-details">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action btn-delete">Delete</a>
                    </td>
        </tr>
}
    </tbody>
</table>
</div>