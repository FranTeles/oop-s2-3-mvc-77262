@model VgcCollege.Web.Models.CourseEnrolment

@{
    ViewData["Title"] = "Create";
}

<div class="page-header">
    <h1>Create Enrolment</h1>
</div>

<div class="form-card">
    <div class="row">
        <div class="col-lg-8">
        <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="StudentProfileId" class="form-label"></label>
                <select asp-for="StudentProfileId" class ="form-control" asp-items="ViewBag.StudentProfileId"></select>
            </div>

                <div class="mb-3">
                    <label asp-for="CourseId" class="form-label"></label>
                <select asp-for="CourseId" class ="form-control" asp-items="ViewBag.CourseId"></select>
            </div>

                <div class="mb-3">
                    <label asp-for="EnrolDate" class="form-label"></label>
                <input asp-for="EnrolDate" class="form-control" />
                <span asp-validation-for="EnrolDate" class="text-danger"></span>
            </div>

                <div class="mb-3">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select"
                            asp-items="Html.GetEnumSelectList<EnrolmentStatus>()">
                    </select>
                </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
