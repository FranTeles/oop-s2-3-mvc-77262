@model IEnumerable<VgcCollege.Web.Models.CourseEnrolment>

@{
    ViewData["Title"] = "Enrolments";
}

<div class="page-header">
    <h2>Course Enrolments</h2>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">New Enrolment</a>
    }
</div>

<div class="table-card">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>Student</th>
                <th>Course</th>
                <th>Enrol Date</th>
                <th>Status</th>
                <th style="width: 240px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.StudentProfile?.Name</td>
                    <td>@item.Course?.Name</td>
                    <td>@item.EnrolDate.ToShortDateString()</td>
                    <td>@item.Status</td>
                    <td class="table-actions">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-details">Details</a>

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-edit">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action btn-delete">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>