@model VgcCollege.Web.Models.AssignmentResult

@{
    ViewData["Title"] = "Create";
}

<div class="page-header">
    <h1>Create Gradebook</h1>
</div>

<div class="form-card">
    <div class="row">
        <div class="col-lg-8">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="mb-3">
                    <label asp-for="AssignmentId" class="form-label"></label>
                <select asp-for="AssignmentId" class ="form-control" asp-items="ViewBag.AssignmentId"></select>
            </div>
                <div class="mb-3">
                    <label asp-for="StudentProfileId" class="form-label"></label>
                <select asp-for="StudentProfileId" class ="form-control" asp-items="ViewBag.StudentProfileId"></select>
            </div>
                <div class="mb-3">
                    <label asp-for="Score" class="form-label"></label>
                <input asp-for="Score" class="form-control" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>
                <div class="mb-3">
                    <label asp-for="Feedback" class="form-label"></label>
                <input asp-for="Feedback" class="form-control" />
                <span asp-validation-for="Feedback" class="text-danger"></span>
            </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
        </form>
    </div>
</div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
