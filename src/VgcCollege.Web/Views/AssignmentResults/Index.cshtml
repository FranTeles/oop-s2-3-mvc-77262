@model IEnumerable<VgcCollege.Web.Models.AssignmentResult>

@{
    ViewData["Title"] = "Gradebook";
}

<div class="page-header">
    <h2>Assignment Gradebook</h2>

    @if (User.IsInRole("Admin") || User.IsInRole("Faculty"))
    {
        <a asp-action="Create" class="btn btn-primary">Add Result</a>
    }
</div>

<div class="table-card">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>Student</th>
                <th>Assignment</th>
                <th>Course</th>
                <th>Score</th>
                <th>Feedback</th>
                <th style="width: 260px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.StudentProfile?.Name</td>
                    <td>@item.Assignment?.Title</td>
                    <td>@item.Assignment?.Course?.Name</td>
                    <td>
                        <span class="badge bg-primary">@item.Score</span>
                    </td>
                    <td>@item.Feedback</td>
                    <td class="table-actions">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-details">Details</a>

                        @if (User.IsInRole("Admin") || User.IsInRole("Faculty"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-edit">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action btn-delete">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>