@{
    ViewData["Title"] = "Home";
}

<div class="hero-box text-center mb-5">
    <h1>Welcome to VGC College</h1>
    <p class="mt-3 mb-4">
        A simple academic management system for administrators, faculty, and students.
    </p>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        if (User.IsInRole("Admin"))
        {
            <a class="btn btn-primary btn-lg" asp-controller="Home" asp-action="AdminDashboard">Go to Admin Dashboard</a>
        }
        else if (User.IsInRole("Faculty"))
        {
            <a class="btn btn-primary btn-lg" asp-controller="Home" asp-action="FacultyDashboard">Go to Faculty Dashboard</a>
        }
        else if (User.IsInRole("Student"))
        {
            <a class="btn btn-primary btn-lg" asp-controller="Home" asp-action="StudentDashboard">Go to Student Dashboard</a>
        }
    }
    else
    {
        <a class="btn btn-primary btn-lg" asp-area="Identity" asp-page="/Account/Login">Login</a>
    }
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="dashboard-card">
            <h5>Admin Management</h5>
            <p>Manage branches, courses, enrolments, staff assignments, and exam release.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dashboard-card">
            <h5>Faculty Access</h5>
            <p>View assigned courses, students, attendance, and academic progress data.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dashboard-card">
            <h5>Student Portal</h5>
            <p>Check released exam results and access information relevant to your account.</p>
        </div>
    </div>
</div>