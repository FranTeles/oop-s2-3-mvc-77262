@using Microsoft.AspNetCore.Identity
@using System.Security.Claims

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VGC College</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VgcCollege.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm custom-navbar">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">VGC College</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Home" asp-action="AdminDashboard">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Branches" asp-action="Index">Branches</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Courses" asp-action="Index">Courses</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="StudentProfiles" asp-action="Index">Students</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="CourseEnrolments" asp-action="Index">Enrolments</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AttendanceRecords" asp-action="Index">Attendance</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Assignments" asp-action="Index">Assignments</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AssignmentResults" asp-action="Index">Gradebook</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Exams" asp-action="Index">Exams</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="ExamResults" asp-action="Index">Exam Results</a>
                                </li>
                            }
                            else if (User.IsInRole("Faculty"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Home" asp-action="FacultyDashboard">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Courses" asp-action="Index">My Courses</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="StudentProfiles" asp-action="Index">My Students</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AttendanceRecords" asp-action="Index">Attendance</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Assignments" asp-action="Index">Assignments</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AssignmentResults" asp-action="Index">Gradebook</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Exams" asp-action="Index">Exams</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="ExamResults" asp-action="Index">Exam Results</a>
                                </li>
                            }
                            else if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Home" asp-action="StudentDashboard">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="ExamResults" asp-action="MyResults">My Results</a>
                                </li>
                            }
                        }
                    </ul>

                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="page-wrapper">
        <div class="container py-4">
            @RenderBody()
        </div>
    </main>

    <footer class="footer custom-footer">
        <div class="container text-center">
            &copy; 2026 - VGC College Management System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>