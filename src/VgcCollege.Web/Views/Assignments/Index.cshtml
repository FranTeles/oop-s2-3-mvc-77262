@model IEnumerable<VgcCollege.Web.Models.Assignment>

@{
    ViewData["Title"] = "Index";
}

<div class="page-header">
    <h2>Assignment</h2>
    <a asp-action="Create" class="btn btn-primary">Create New Assignment</a>
</div>

<div class="table-card">
    <table class="table table-hover align-middle mb-0">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Course)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MaxScore)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DueDate)
            </th>
                <th style="width: 240px;">Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Course.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MaxScore)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DueDate)
            </td>
                    <td class="table-actions">
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-edit">Edit</a> 
                <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-details">Details</a> 
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action btn-delete">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
</div>
